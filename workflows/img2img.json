{
  "__params__": {
    "prompt":          { "node": "2",  "field": "text" },
    "negative_prompt": { "node": "3",  "field": "text" },
    "denoise":         { "node": "6",  "field": "denoise" },
    "seed":            { "node": "6",  "field": "seed" },
    "steps":           { "node": "6",  "field": "steps" },
    "cfg":             { "node": "6",  "field": "cfg" },
    "checkpoint":      { "node": "1",  "field": "ckpt_name" },
    "image":           { "node": "10", "field": "image" }
  },

  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "v1-5-pruned-emaonly.ckpt"
    }
  },
  "2": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "edited image",
      "clip": ["1", 1]
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "ugly, blurry, low quality, watermark",
      "clip": ["1", 1]
    }
  },
  "4": {
    "class_type": "VAEEncode",
    "inputs": {
      "pixels": ["10", 0],
      "vae":    ["1", 2]
    }
  },
  "6": {
    "class_type": "KSampler",
    "inputs": {
      "seed": 42,
      "steps": 30,
      "cfg": 7.0,
      "sampler_name": "euler",
      "scheduler": "normal",
      "denoise": 0.75,
      "model":        ["1", 0],
      "positive":     ["2", 0],
      "negative":     ["3", 0],
      "latent_image": ["4", 0]
    }
  },
  "7": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["6", 0],
      "vae":     ["1", 2]
    }
  },
  "9": {
    "class_type": "SaveImage",
    "inputs": {
      "filename_prefix": "comfy_img2img",
      "images": ["7", 0]
    }
  },
  "10": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "input.png"
    }
  }
}
